# ── Telegram USER credentials (from my.telegram.org → App API)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1234567890

# ── Telegram BOT token (from @BotFather → /newbot)
BOT_TOKEN=your_bot_token

# ── Your personal Telegram user ID (get from @userinfobot)
YOUR_CHAT_ID=your_numeric_user_id

# ── Anthropic API key (for parsing messages)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Google Sheets (service account JSON file path + spreadsheet ID)
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
SPREADSHEET_ID=your_spreadsheet_id

# ── Telegram group/channel usernames or IDs to monitor
# Comma-separated. Use @username or numeric ID (-100XXXXXXXXX)
MONITORED_GROUPS=-1001234567890,-1009876543210

# ── Alert thresholds (% from target or SL)
ALERT_THRESHOLD_PERCENT=2.0
